<div class="min-h-screen bg-slate-950 text-white px-6 py-24">

  <div class="max-w-7xl mx-auto">

    <h1 class="text-5xl font-black mb-12">
      Pedidos
    </h1>

    <div class="space-y-6">

      <% @orders.each do |order| %>

        <div class="bg-slate-900 border border-white/10 rounded-3xl p-6">

          <div class="grid grid-cols-2 gap-6">

            <div>

              <h2 class="text-xl font-bold text-green-400">
                #<%= order.order_number %>
              </h2>

              <p class="text-slate-400 mt-2">
                <%= order.full_name %>
              </p>

              <p class="text-slate-400">
                <%= order.city %>, <%= order.country %>
              </p>

            </div>

            <div class="text-right min-w-[140px]">

              <p class="font-bold text-xl">
                €<%= number_with_precision(order.total, precision: 2) %>
              </p>

              <p class="text-slate-400">
                <%= order.payment_method %>
              </p>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  </div>

</div>