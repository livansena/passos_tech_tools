<div class="min-h-screen bg-slate-950 text-white">

  <nav class="fixed top-0 left-0 w-full border-b border-white/10 bg-slate-950/80 backdrop-blur-xl z-50">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

      <h1 class="text-2xl font-bold tracking-wide">
        PASSOS <span class="text-green-400">TECH TOOLS</span>
      </h1>

      <div class="hidden md:flex items-center gap-10 text-sm uppercase tracking-wider text-slate-300">

        <a href="#" class="hover:text-green-400 transition">
          Home
        </a>

        <%= link_to "Products", products_path, class: "hover:text-green-400 transition" %>

        <a href="#" class="hover:text-green-400 transition">
          Categories
        </a>

        <a href="#" class="hover:text-green-400 transition">
          About
        </a>

        <a href="#" class="hover:text-green-400 transition">
          Contact
        </a>

        <%= link_to cart_path, class: "relative flex items-center justify-center w-10 h-10 hover:text-green-400 transition" do %>

  <i class="text-xl">🛍️</i> 

  <% if @cart_count > 0 %>
  <span class="absolute -top-2 -right-2 bg-green-400 text-black text-[10px] font-bold rounded-full w-5 h-5 flex items-center justify-center border-2 border-slate-800 shadow-lg">
    <%= @cart_count %>
  </span>
<% end %>

<% end %>

      </div>

    </div>
  </nav>

  <section class="min-h-screen pt-28 px-6 flex items-center">

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div>

        <p class="text-green-400 uppercase tracking-[0.3em] mb-6">
          Passos Tech Tools
        </p>

        <h2 class="text-5xl md:text-7xl font-black leading-tight mb-8">
          Industrial tools.
          <br>
          Modern experience.
        </h2>

        <p class="text-slate-400 text-lg md:text-xl max-w-xl mb-10">
          Premium tools and smart workspace accessories designed for productivity and modern professionals.
        </p>

        <div class="flex gap-4">

          <button class="bg-green-400 text-black px-8 py-4 rounded-full font-semibold hover:scale-105 transition">
            Shop Now
          </button>

          <button class="border border-white/20 px-8 py-4 rounded-full hover:border-green-400 hover:text-green-400 transition">
            Explore Products
          </button>

        </div>

      </div>

      <div class="relative">

        <div class="absolute -inset-6 bg-green-400/20 blur-3xl rounded-full"></div>

        <div class="relative rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 shadow-2xl">

          <div class="h-[420px] rounded-2xl bg-slate-900 border border-white/10 flex items-center justify-center">

            <div class="text-center">

              <div class="text-7xl mb-6">
                🛠️
              </div>

              <p class="text-green-400 uppercase tracking-[0.3em] text-sm">
                Premium Workspace
              </p>

              <h3 class="text-3xl font-bold mt-4">
                Smart Tools Collection
              </h3>

              <p class="text-slate-400 mt-4 max-w-sm">
                Lighting, organization and productivity tools for modern workspaces.
              </p>

            </div>

          </div>

        </div>

      </div>

    </div>

  </section>

  <section class="pb-24 px-6">

    <div class="max-w-7xl mx-auto">

      <div class="flex items-center justify-between mb-12">

        <div>

          <p class="text-green-400 uppercase tracking-[0.3em] text-sm mb-3">
            Featured Products
          </p>

          <h2 class="text-4xl font-bold">
            Smart tools for modern workspaces
          </h2>

        </div>

        <button class="hidden md:block border border-white/10 px-6 py-3 rounded-full hover:border-green-400 hover:text-green-400 transition">
          View All Products
        </button>

      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
<% @products.each do |product| %>
  <%= link_to product_path(product), class: "group block bg-white/5 border border-white/10 rounded-3xl overflow-hidden hover:border-green-400/40 hover:-translate-y-2 hover:shadow-[0_0_40px_rgba(74,222,128,0.15)] transition duration-500" do %>

    <div class="relative h-64 bg-slate-900 flex items-center justify-center text-7xl overflow-hidden">
      <div class="absolute top-4 left-4 bg-green-400 text-black text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
        Best Seller
      </div>

      <%= image_tag product.image, class: "w-full h-full object-cover" if product.image.attached? %>
    </div>

    <div class="p-6">
      <p class="text-slate-400 text-sm mb-2">
        <%= product.category %>
      </p>

      <h3 class="text-2xl font-bold mb-3">
        <%= product.name %>
      </h3>

      <p class="text-slate-400 mb-5">
        <%= product.description %>
      </p>

      <div class="flex text-yellow-400 text-sm mb-4">
        ★★★★★
      </div>

      <div class="flex items-center justify-between">
        <span class="text-2xl font-bold text-green-400">
          €<%= number_with_precision(product.price, precision: 2) %>
        </span>

        <span class="bg-green-400 text-black px-4 py-2 rounded-full text-sm font-semibold">
          Add
        </span>
      </div>
    </div>

  <% end %>
<% end %>

      </div>

    </div>

  </section>

