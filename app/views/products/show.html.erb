<div class="min-h-screen bg-slate-950 text-white px-6 py-24">

  <div class="max-w-7xl mx-auto">

    <%= link_to "← Back to store", root_path, class: "text-green-400 hover:text-green-300 transition" %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mt-12">

      <div class="rounded-3xl overflow-hidden border border-white/10 bg-slate-900">
        <%= image_tag @product.image, class: "w-full h-[480px] object-cover" if @product.image.attached? %>
      </div>

      <div>
        <p class="text-green-400 uppercase tracking-[0.3em] mb-4">
          <%= @product.category %>
        </p>

        <h1 class="text-5xl font-black mb-6">
          <%= @product.name %>
        </h1>

        <p class="text-slate-400 text-xl mb-8">
          <%= @product.description %>
        </p>

        <div class="text-yellow-400 mb-6">
          ★★★★★
        </div>

        <p class="text-5xl font-black text-green-400 mb-10">
          €<%= number_with_precision(@product.price, precision: 2) %>
        </p>

        <div class="flex items-center gap-4 mb-8">

        <button class="w-12 h-12 rounded-full bg-slate-900 border border-white/10 text-xl hover:border-green-400 transition">
        -
        </button>

        <div class="w-14 h-12 rounded-full bg-slate-900 border border-white/10 flex items-center justify-center font-bold">
        1
        </div>

          <button class="w-12 h-12 rounded-full bg-slate-900 border border-white/10 text-xl hover:border-green-400 transition">
        +
        </button>

      </div>

        <%= button_to "Add to Cart",
        cart_items_path(product_id: @product.id),
        method: :post,
        class: "bg-green-400 text-black px-10 py-4 rounded-full font-bold hover:scale-105 transition" %>

        <div class="mt-14 border-t border-white/10 pt-10">

         <h2 class="text-2xl font-bold mb-6">
          Technical Specifications
        </h2>

  <div class="grid grid-cols-2 gap-6 text-slate-300">

    <div class="bg-slate-900 border border-white/10 rounded-2xl p-5">
      <p class="text-sm text-slate-500 mb-2">Material</p>
      <p>Industrial Grade Aluminum</p>
    </div>

    <div class="bg-slate-900 border border-white/10 rounded-2xl p-5">
      <p class="text-sm text-slate-500 mb-2">Warranty</p>
      <p>2 Years</p>
    </div>

    <div class="bg-slate-900 border border-white/10 rounded-2xl p-5">
      <p class="text-sm text-slate-500 mb-2">Shipping</p>
      <p>Worldwide Delivery</p>
    </div>

    <div class="bg-slate-900 border border-white/10 rounded-2xl p-5">
      <p class="text-sm text-slate-500 mb-2">Quality</p>
      <p>Premium Professional</p>
    </div>

  </div>

  </div>

      </div>

    </div>

  </div>

  <div class="max-w-7xl mx-auto">
    <h2 class="text-4xl font-black mb-10">
  You may also like
</h2>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8">

  <% Product.limit(3).each do |product| %>

    <%= link_to product_path(product),
    class: "group bg-slate-900 border border-white/10 rounded-3xl overflow-hidden hover:border-green-400/50 transition duration-500" do %>

      <% if product.image.attached? %>
        <%= image_tag product.image,
        class: "w-full h-56 object-cover group-hover:scale-105 transition duration-500" %>
      <% end %>

      <div class="p-6">

        <p class="text-green-400 uppercase tracking-[0.2em] text-xs mb-3">
          <%= product.category %>
        </p>

        <h3 class="text-2xl font-bold mb-4">
          <%= product.name %>
        </h3>

        <p class="text-green-400 text-3xl font-black">
          €<%= number_with_precision(product.price, precision: 2) %>
        </p>

      </div>

    <% end %>

  <% end %>

</div> 

</div>